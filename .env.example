# Engy environment variables
# Copy to .dev.env for development (loaded by `pnpm dev`)
# Copy to .env for production (loaded by `pnpm start`)

# Web server
PORT=3000
ENGY_DIR=~/.engy/          # Dev override: .dev-engy/ (project-local, gitignored)

# Client daemon
ENGY_SERVER_URL=http://localhost:3000
